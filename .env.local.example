NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Moderation: console.anthropic.com -> API keys (phone verification, no card
# needed for the $5 free trial). Set a spend limit under Console -> Limits.
ANTHROPIC_API_KEY=

# Shared secret the pins-insert DB trigger sends when calling
# /api/webhooks/new-pin. Must also be stored in Supabase Vault as
# 'new_pin_webhook_secret' (see supabase/migrations/0005_admin.sql).
WEBHOOK_SECRET=

# Email-on-new-pin: resend.com -> API keys (free tier, no card needed)
RESEND_API_KEY=
# Where new-pin notifications get sent
ADMIN_EMAIL=
